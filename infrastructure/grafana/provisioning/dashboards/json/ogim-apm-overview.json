{
  "id": null,
  "uid": "ogim-apm-overview",
  "title": "OGIM APM Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate by Service",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(service_requests_total[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate by Service",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(service_request_errors_total[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P95 Latency (API Gateway)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(service_request_latency_seconds_bucket{service=\"api-gateway\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "ML Inference Latency (p95)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ml_inference_latency_seconds_bucket[5m])) by (le, model_type))",
          "legendFormat": "{{model_type}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}

